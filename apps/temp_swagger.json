{
    "schemes": [],
    "swagger": "2.0",
    "info": {
        "description": "Микросервис для получения данных о температуре с датчиков умного дома",
        "title": "Temperature API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8081",
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "Endpoint для проверки работоспособности сервиса",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Проверка состояния сервиса",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/temperature": {
            "get": {
                "description": "Возвращает случайное значение температуры для указанной комнаты",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Temperature"
                ],
                "summary": "Получить температуру по названию комнаты",
                "parameters": [
                    {
                        "enum": [
                            "Living Room",
                            "Bedroom",
                            "Kitchen"
                        ],
                        "type": "string",
                        "description": "Название комнаты",
                        "name": "location",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.TemperatureData"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/temperature/{id}": {
            "get": {
                "description": "Возвращает случайное значение температуры для указанного датчика",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Temperature"
                ],
                "summary": "Получить температуру по ID датчика",
                "parameters": [
                    {
                        "enum": [
                            "1",
                            "2",
                            "3"
                        ],
                        "type": "string",
                        "description": "ID датчика",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.TemperatureData"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "main.TemperatureData": {
            "type": "object",
            "properties": {
                "description": {
                    "type": "string"
                },
                "location": {
                    "type": "string"
                },
                "sensor_id": {
                    "type": "string"
                },
                "sensor_type": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string"
                },
                "unit": {
                    "type": "string"
                },
                "value": {
                    "type": "number"
                }
            }
        }
    }
}