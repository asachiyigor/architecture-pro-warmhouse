@startuml
!pragma charset UTF-8
skinparam defaultFontName "Segoe UI"
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Диаграмма контекста монолитной системы "Тёплый дом" (AS-IS)

Person(homeowner, "Владелец дома", "Житель дома, управляющий отоплением и просматривающий температуру через веб-интерфейс")
Person(technician, "Специалист по подключению", "Техник компании, выезжающий для установки и подключения оборудования к системе")

System(warm_house_system, "Монолитная система «Тёплый дом»", "Go-приложение с PostgreSQL для удалённого управления отоплением и мониторинга температуры")

System_Ext(heating_controllers, "Контроллеры отопления", "Специальные реле для включения/выключения отопления в домах")
System_Ext(temperature_sensors, "Температурные датчики", "Датчики для измерения температуры в домах (установлены не везде)")

Enterprise_Boundary(regions, "Регионы присутствия") {
    System_Ext(existing_houses, "Подключенные дома", "Дома с установленными датчиками и реле (≈50% от желающих)")
    System_Ext(pending_houses, "Дома в ожидании", "Дома без оборудования, ожидающие подключения специалиста")
}

' ПОЛЬЗОВАТЕЛЬСКИЕ ВЗАИМОДЕЙСТВИЯ
Rel(homeowner, warm_house_system, "Управляет отоплением, просматривает температуру", "HTTPS/Web")
Rel(technician, warm_house_system, "Регистрирует новое оборудование в системе", "HTTPS/Web")

' СИСТЕМНЫЕ ВЗАИМОДЕЙСТВИЯ С УСТРОЙСТВАМИ
Rel(warm_house_system, heating_controllers, "Команды включения/выключения отопления", "Синхронные запросы")
Rel(warm_house_system, temperature_sensors, "Опрос температурных показаний", "Синхронные запросы")

' СВЯЗИ С ДОМАМИ
Rel(heating_controllers, existing_houses, "Установлены в домах", "Физическое присутствие")
Rel(temperature_sensors, existing_houses, "Измеряют температуру", "Физическое присутствие")
Rel(technician, existing_houses, "Выезжает для установки", "Физический визит")
Rel(technician, pending_houses, "Планирует подключение", "Заявки")

' КОНТЕКСТНЫЕ ПРИМЕЧАНИЯ
note right of warm_house_system : **МОНОЛИТНАЯ СИСТЕМА:**\n• Язык: Go\n• БД: PostgreSQL\n• Архитектура: Монолит\n• Протоколы: Только синхронные\n• Инициатор: Сервер → Устройство\n• Функции: Отопление + Температура

note left of regions : **ТЕКУЩИЕ ОГРАНИЧЕНИЯ:**\n• Только 50% домов подключены\n• Требуется выезд специалиста\n• Самостоятельное подключение невозможно\n• Функционал ограничен отоплением\n• Масштабирование затруднено

note bottom : **БИЗНЕС-КОНТЕКСТ:**\n📍 **Текущее состояние:** Управление отоплением в частных домах\n🎯 **Цель развития:** Экосистема умных посёлков в нескольких регионах\n⚠️ **Проблема:** Монолит не подходит для масштабирования и расширения функционала

@enduml